  "files": {
    ".github/workflows/lint.yml": {
      "regex": [
        "mise"
      ]
    },
    ".github/workflows/mise-registry.yml": {
      "regex": [
        "mise"
      ]
    },
    ".github/workflows/release-plz.yml": {
      "regex": [
        "mise"
      ]
    },
    ".github/workflows/release.yml": {
      "regex": [
        "mise"
      ]
    },
    ".github/workflows/test.yml": {
      "regex": [
        "mise"
      ]
    },
    "mise.toml": {
      "mise": [
        "actionlint",
        "aqua:jonwiggins/xmloxide",
        "aqua:owenlamont/ryl",
        "biome",
        "dotenv-linter",
        "dotnet",
        "editorconfig-checker",
        "go",
        "golangci-lint",
        "google-java-format",
        "hadolint",
        "ktlint",
        "lychee",
        "node",
        "npm:renovate",
        "release-plz",
        "ruff",
        "rumdl",
        "rust",
        "shellcheck",
        "shfmt",
        "taplo",
        "typos",
        "zizmor"
      ]
    },
    "src/init/scaffold.rs": {
      "regex": [
        "Swatinem/rust-cache",
        "actions/checkout",
        "jdx/mise-action",
        "mise"
      ]
    }
  }
}
