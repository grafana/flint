{
  ".github/workflows/lint.yml": {
    "regex": [
      "mise"
    ]
  },
  "README.md": {
    "regex": [
      "grafana/flint"
    ]
  },
  "mise.toml": {
    "mise": [
      "actionlint",
      "editorconfig-checker",
      "lychee",
      "node",
      "npm:@biomejs/biome",
      "npm:markdownlint-cli",
      "npm:prettier",
      "npm:renovate",
      "pipx:codespell",
      "pipx:ruff",
      "shellcheck",
      "shfmt"
    ]
  }
}
