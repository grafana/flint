{
  ".github/workflows/lint.yml": {
    "regex": [
      "mise"
    ]
  },
  ".github/workflows/release.yml": {
    "regex": [
      "mise"
    ]
  },
  ".github/workflows/test.yml": {
    "regex": [
      "mise"
    ]
  },
  "README.md": {
    "regex": [
      "grafana/flint"
    ]
  },
  "mise.toml": {
    "mise": [
      "actionlint",
      "biome",
      "cargo:xmloxide",
      "cargo:yaml-lint",
      "dotnet",
      "editorconfig-checker",
      "github:google/google-java-format",
      "github:koalaman/shellcheck",
      "github:pinterest/ktlint",
      "go",
      "golangci-lint",
      "hadolint",
      "lychee",
      "node",
      "npm:renovate",
      "pipx:codespell",
      "pipx:ruff",
      "rumdl",
      "rust",
      "shfmt"
    ]
  },
  "src/init/generation.rs": {
    "regex": [
      "Swatinem/rust-cache",
      "actions/checkout",
      "jdx/mise-action",
      "mise"
    ]
  }
}
