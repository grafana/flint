{
  ".github/workflows/lint.yml": {
    "regex": [
      "mise"
    ]
  },
  "README.md": {
    "regex": [
      "grafana/flint"
    ]
  },
  "mise.toml": {
    "mise": [
      "bats",
      "editorconfig-checker",
      "lychee",
      "node",
      "npm:renovate"
    ],
    "regex": [
      "ghcr.io/super-linter/super-linter"
    ]
  }
}
